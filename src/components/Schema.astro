---
import { SITE, CITIES } from '../data/site';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'he',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.url}/blog?q={search_term_string}`
    },
    'query-input': 'required name=search_term_string'
  }
};

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'HomeAndConstructionBusiness'],
  '@id': `${SITE.url}/#business`,
  name: SITE.name,
  alternateName: 'בבא גיזום',
  description: SITE.description,
  url: SITE.url,
  telephone: `+972${SITE.phoneRaw.replace(/^0/, '')}`,
  email: SITE.email,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/images/logo.jpeg`,
    width: 1200,
    height: 1200
  },
  image: `${SITE.url}/images/og-image.jpg`,
  priceRange: '₪₪',
  currenciesAccepted: 'ILS',
  paymentAccepted: 'Cash, Credit Card, Bank Transfer, Bit, PayBox',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'IL',
    addressLocality: 'ישראל'
  },
  areaServed: CITIES.map(c => ({
    '@type': 'City',
    name: c.name
  })),
  knowsAbout: [
    'גיזום עצים',
    'כריתת עצים',
    'גיזום דקלים',
    'פינוי גזם',
    'כרסום גזעים',
    'עבודה בגובה',
    'אישור פקיד יערות',
    'עבודה ללא מנוף',
    'טיפוס על עצים'
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'שירותי גיזום וכריתת עצים',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'גיזום עצים',
          description: 'גיזום מקצועי לעצים בכל גובה בטיפוס ללא מנוף',
          url: `${SITE.url}/services/gizum-etzim`
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'כריתת עצים',
          description: 'כריתה בטוחה עם סיוע בקבלת אישור פקיד יערות',
          url: `${SITE.url}/services/kritat-etzim`
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'גיזום דקלים',
          description: 'גיזום דקלים מכל גובה — וושינגטוניה, תמר, קנרי ועוד',
          url: `${SITE.url}/services/gizum-deklim`
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'פינוי גזם',
          description: 'פינוי מלא של גזם לאחר גיזום, סופה או עבודות חצר',
          url: `${SITE.url}/services/pinui-gezem`
        }
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'כרסום גזעים ושורשים',
          description: 'כרסום מקצועי של גדמות עצים ושורשים לאחר כריתה',
          url: `${SITE.url}/services/kirssum-gdamot`
        }
      }
    ]
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '7',
    bestRating: '5',
    worstRating: '1'
  },
  review: [
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'רונית כ.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'עץ ענק שנשען על הבית. הגיעו תוך יום, גזמו במקצועיות בלי מנוף בכלל ובמחיר הוגן. מומלץ בלב שלם.',
      datePublished: '2026-01-10'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'אבי ל.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'שלחתי תמונה בוואטסאפ, קיבלתי הצעת מחיר תוך עשר דקות, הגיעו בזמן ועשו עבודה מסודרת ומקצועית.',
      datePublished: '2026-02-03'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'יוסי ב.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'עזרו לי גם בהוצאת האישור מהעירייה. שירות מצוין, מקצועי ואדיב.',
      datePublished: '2026-03-05'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'מרים ש.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'גיזמו לנו דקל וושינגטוניה ענק בגינה — עבודה בגובה מרשימה לחלוטין. הכל נקי ומסודר, ממליצה בחום.',
      datePublished: '2026-03-18'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'דני א.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'כרתו עץ אורן ישן שהיה מסוכן קרוב לגדר. עבדו מהר, בבטיחות ובמחיר שהפתיע אותי לטובה.',
      datePublished: '2026-04-02'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'חני מ.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'ניסיתי לקבל הצעות ממספר גוזמים — בב"א הכי הגיוניים במחיר והכי מקצועיים בביצוע. בהחלט אחזור.',
      datePublished: '2026-04-20'
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'שלומי ר.' },
      reviewRating: { '@type': 'Rating', ratingValue: '5' },
      reviewBody: 'גיזום עצי זית בגינה גדולה — עשו עבודה יסודית וידעו בדיוק אילו ענפים להסיר. שירות מהיר ואמין.',
      datePublished: '2026-05-08'
    }
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
      opens: '07:00',
      closes: '19:00'
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Friday',
      opens: '07:00',
      closes: '13:00'
    }
  ],
  sameAs: [
    `https://wa.me/${SITE.whatsapp}`,
    'https://www.facebook.com/babagizum',
    'https://www.google.com/maps/search/babagizum'
  ]
};
---
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
