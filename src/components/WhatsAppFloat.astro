---
import { SITE } from '../data/site';
const message = encodeURIComponent('שלום, אשמח לקבל הצעת מחיר לגיזום/כריתת עץ. מצורפת תמונה.');
---
<a
  href={`https://wa.me/${SITE.whatsapp}?text=${message}`}
  target="_blank"
  rel="noopener"
  aria-label="פתח שיחת וואטסאפ"
  class="fixed bottom-5 left-5 z-50 inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1da851] text-white px-4 py-3 rounded-full shadow-strong transition-all duration-200 hover:scale-105"
>
  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.6 6.32A8.78 8.78 0 0012 4 8.84 8.84 0 003.16 12.84 8.7 8.7 0 004.4 17.5L4 20l2.6-.36A8.83 8.83 0 0012 21.68 8.84 8.84 0 0020.84 12.84 8.78 8.78 0 0017.6 6.32zm-5.6 13.86a7.34 7.34 0 01-3.7-1l-.27-.16-1.55.21.21-1.5-.18-.28A7.34 7.34 0 014.66 12.84 7.34 7.34 0 0112 5.5a7.34 7.34 0 017.34 7.34A7.34 7.34 0 0112 20.18zm4.04-5.5c-.22-.11-1.31-.65-1.51-.72-.2-.07-.35-.11-.5.11-.14.22-.57.72-.7.86-.13.15-.26.16-.48.05a6 6 0 01-1.77-1.09 6.66 6.66 0 01-1.23-1.53c-.13-.22 0-.34.1-.45l.34-.4a1.55 1.55 0 00.22-.37.4.4 0 000-.4c-.06-.11-.5-1.2-.68-1.65-.18-.42-.36-.36-.5-.37H8.92a.78.78 0 00-.57.27 2.4 2.4 0 00-.74 1.78 4.18 4.18 0 00.86 2.21 9.5 9.5 0 003.62 3.2 12.16 12.16 0 001.21.45 2.91 2.91 0 001.34.08 2.19 2.19 0 001.43-1 1.78 1.78 0 00.13-1c-.05-.1-.2-.16-.42-.27z"/></svg>
  <span class="hidden sm:inline font-semibold">שלחו לי הצעת מחיר</span>
</a>
