---
import BaseLayout from './BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQSchema from '../components/FAQSchema.astro';
import ServiceSchema from '../components/ServiceSchema.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  faqs?: { q: string; a: string }[];
}

const { title, description, h1, intro, faqs = [] } = Astro.props;
const serviceUrl = `${SITE.url}${Astro.url.pathname}`;
---
<BaseLayout title={title} description={description}>
  {faqs.length > 0 && <FAQSchema slot="head-extra" faqs={faqs} />}
  <ServiceSchema slot="head-extra" name={h1} description={description} url={serviceUrl} />

  <section class="bg-gradient-to-bl from-forest-900 via-forest-800 to-forest-700 text-white">
    <div class="container-x section">
      <nav class="text-sm text-sand-200 mb-4" aria-label="פירורי לחם">
        <a href="/" class="hover:text-white">בית</a>
        <span class="mx-2">›</span>
        <span class="text-white">{h1}</span>
      </nav>
      <div class="grid lg:grid-cols-3 gap-6 lg:gap-10 items-start">
        <div class="lg:col-span-2">
          <h1 class="h1 text-white mb-4 sm:mb-5">{h1}</h1>
          <p class="lead !text-sand-100 max-w-2xl">{intro}</p>
          <div class="mt-6 sm:mt-8 flex flex-col sm:flex-row gap-3">
            <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener" class="btn-whatsapp">שלחו תמונה בוואטסאפ</a>
            <a href={`tel:${SITE.phoneRaw}`} class="btn-accent">{SITE.phone}</a>
          </div>
        </div>
        <div class="hidden lg:block bg-white rounded-2xl p-1.5 shadow-strong">
          <div class="bg-forest-900 rounded-xl px-5 py-3 text-white font-semibold">קבלו הצעת מחיר עכשיו</div>
          <div class="p-5"><ContactForm /></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-x grid lg:grid-cols-3 gap-6 lg:gap-10">
      <article class="lg:col-span-2 prose prose-lg max-w-none [&_h2]:text-forest-900 [&_h2]:mt-8 [&_h2]:sm:mt-10 [&_h2]:mb-4 [&_h2]:text-2xl [&_h2]:sm:text-3xl [&_h2]:font-bold [&_h3]:text-forest-900 [&_h3]:mt-6 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-bold [&_p]:leading-relaxed [&_p]:text-forest-800 [&_ul]:list-disc [&_ul]:pr-5 [&_ul]:space-y-2 [&_li]:text-forest-800 [&_a]:text-forest-700 [&_a]:underline">
        <slot />
      </article>
      <aside class="space-y-6">
        <div class="bg-forest-50 rounded-2xl p-4 sm:p-6 sticky top-24">
          <h3 class="font-bold text-forest-900 mb-3">צריכים שירות עכשיו?</h3>
          <p class="text-forest-700 mb-4">שלחו תמונה ותקבלו הצעת מחיר תוך דקות.</p>
          <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener" class="btn-whatsapp w-full mb-2">וואטסאפ</a>
          <a href={`tel:${SITE.phoneRaw}`} class="btn-primary w-full">{SITE.phone}</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
