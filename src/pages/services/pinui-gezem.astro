---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const faqs = [
  { q: 'אתם מפנים גזם גם בלי שביצעתם את הגיזום?', a: 'כן, אנחנו לוקחים גזם שגוזם מישהו אחר או שנפל בסערה, בתשלום לפי כמות. שלחו תמונה של הערימה ונשלח לכם הצעת מחיר.' },
  { q: 'כמה זמן לוקח לפנות גזם?', a: 'תלוי בכמות. ערימה רגילה — שעה-שעתיים. גם אם יש המון, בדרך כלל אפשר לסיים תוך חצי יום עבודה.' },
  { q: 'לאן הגזם הולך?', a: 'אנחנו מובילים את הגזם לאתר פסולת מורשה (תחנת מעבר ירוקה). שם הוא עובר גריסה לקומפוסט או לשבבים לחיפוי. אנחנו לא משאירים גזם ברחוב או בשטחים פתוחים.' },
  { q: 'אפשר לקחת גם גזעים גדולים?', a: 'כן, גם גזעים בקוטר משמעותי. במקרים של גזעים מאוד גדולים (מעל 60 ס"מ קוטר) ניתן בנוסף שירות חיתוך לאורך לחיתוכי הסקה.' }
];
---
<ServiceLayout
  title="פינוי גזם מקצועי — בב״א גיזום | פינוי לאחר גיזום או סופה"
  description="פינוי מקצועי של גזם וענפים — אחרי גיזום, סופה או עבודות חצר. הובלה לאתר פסולת מורשה, ללא נזק למדרכה. שירות מהיר ומחיר הוגן בכל הארץ."
  h1="פינוי גזם — אנחנו עוזבים את השטח נקי"
  intro="פינוי גזם הוא חלק בלתי נפרד מכל גיזום או כריתה אצלנו. אבל אנחנו גם מספקים שירות פינוי עצמאי — אם גזמתם בעצמכם, אם הייתה סערה ויש לכם ערימה בחצר, או אם השכן הזניח. אנחנו מגיעים, אורזים, מובילים — ומשאירים שטח נקי."
  faqs={faqs}
>
  <h2>שירות פינוי גזם — מה כלול</h2>
  <p>פינוי גזם נשמע פשוט, אבל יש בו הרבה דקויות שיכולות להפוך אותו לחוויה לא נעימה אם זה לא נעשה נכון:</p>
  <ul>
    <li>איסוף ידני של כל הענפים מהשטח — גם הקטנים שמתחבאים בין הצמחיה.</li>
    <li>חיתוך הענפים הגדולים לאורכים שניתנים להובלה ברכב.</li>
    <li>אריזה מסודרת בלי לפגוע במדרכה, בריצוף או בצמחיה הסובבת.</li>
    <li>הובלה לאתר פסולת מורשה (לא משאירים בשטח פתוח כמו שעושים חלק מבעלי מקצוע).</li>
    <li>טאטוא ושטיפת אזור העבודה בסיום.</li>
  </ul>

  <h2>מתי לשכור פינוי גזם בנפרד</h2>
  <h3>אחרי גיזום שעשיתם בעצמכם</h3>
  <p>הרבה אנשים גוזמים את העצים שלהם, ופתאום מגלים שיש להם ערימת ענפים שלוקחת רבע מהחצר. במקום לחתוך לאיטכם, להעמיס לרכב פרטי, ולהפיל בנמל ירוק — אנחנו מסיימים תוך שעה.</p>

  <h3>אחרי סופה או רוח חזקה</h3>
  <p>בכל חורף יש סופות שמפילות ענפים גדולים. אם הענף נפל אצלכם בחצר או על המדרכה — אנחנו מגיעים, חותכים, מפנים, וגם בודקים אם נשאר משהו לא יציב על העץ שצריך טיפול.</p>

  <h3>פינוי תקופתי בגינות גדולות</h3>
  <p>גינות גדולות, גני מלכותיים או חצרות מוסדיים שצוברים גזם עונתי — אנחנו עוברים פעם בכמה חודשים ומפנים הכל בבת אחת.</p>

  <h2>למה לא להשאיר את הגזם בכביש?</h2>
  <p>הרבה רשויות מקומיות (בעיקר בערים גדולות) קונסות על השארת גזם בכביש מחוץ למסגרת מועדי פינוי הגזם של העירייה. הקנסות יכולים להגיע למאות שקלים. בנוסף, ערימת גזם פתוחה היא סכנה — ילדים מטפסים, מזיקים מתיישבים, וזה פשוט מכוער.</p>

  <h2>פינוי גזם תעשייתי</h2>
  <p>אנחנו פועלים גם עם רשויות מקומיות, חברות גינון מסחריות, מוסדות חינוך וועדי בית — לפינוי תקופתי בכמויות גדולות. צרו קשר לקבלת הצעת מחיר עסקית.</p>
</ServiceLayout>
