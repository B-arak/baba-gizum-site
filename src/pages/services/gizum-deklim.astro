---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const faqs = [
  { q: 'באיזה תדירות צריך לגזום דקל?', a: 'דקלים נשירים (כמו וושינגטוניה) — פעם בשנה, בדרך כלל באביב או בקיץ, להוצאת כפות יבשות. דקל תמר — פעם בשנה אחרי הקטיף. דקל קנרי או מלכותי — פעם ב-1-2 שנים, בעיקר אסתטית.' },
  { q: 'כמה עולה גיזום דקל?', a: 'מחיר גיזום דקל תלוי בגובה: דקל עד 6 מטר — 250-450 ₪. דקל בינוני 6-12 מטר — 500-900 ₪. דקל גבוה מעל 12 מטר — 1,000-2,000 ₪. במקרה של דקל מאוד גבוה (15-20 מטר ומעלה) המחיר עולה בהתאם.' },
  { q: 'מה ההבדל בין סוגי הדקלים בגיזום?', a: 'וושינגטוניה (היפה והשכיחה ברחובות) — מצריכה גיזום שנתי של כפות יבשות. תמר — צריך גם להוריד פירות מצטברים. קנרי ומלכותי — דקלי נוי, גיזום עדין יותר.' },
  { q: 'אתם עוסקים גם בעקירת דקלים?', a: 'כן. עקירת דקל היא עבודה מורכבת בגלל מערכת השורשים העמוקה. אנחנו מבצעים גם עקירה וגם כרסום הגזע אחרי כריתה.' },
  { q: 'איך מטפסים על דקל?', a: 'באמצעות רתמת טיפוס מקצועית עם רגליים מיוחדות שמתאימות לגזע החלק של הדקל, וחבלים לאבטחה. כל זה תוך שימוש בתעודת עבודה בגובה ובטיחות מלאה.' }
];
---
<ServiceLayout
  title="גיזום דקלים מקצועי בכל גובה — בב״א גיזום | וושינגטוניה, תמר, קנרי"
  description="גיזום דקלים מקצועי לכל הסוגים — וושינגטוניה, תמר, קנרי, מלכותי, שכן ועוד. בכל גובה, ללא צורך במנוף. גוזם מוסמך משרד החקלאות עם תעודת עבודה בגובה."
  h1="גיזום דקלים — בכל גובה, בכל סוג"
  intro="דקלים דורשים תחזוקה תקופתית כדי להישאר בריאים, בטוחים ויפים. אנחנו מתמחים בגיזום כל סוגי הדקלים — מהוושינגטוניה הגבוהה שברחוב ועד דקל הנוי הקטן בגינה. כל זה בלי מנוף וללא נזק לסביבה."
  faqs={faqs}
>
  <div class="rounded-2xl overflow-hidden mb-10 shadow-soft">
    <img src="/images/gizum-dekel-even.jpeg"
         alt="גיזום דקל תמר בטיפוס מקצועי ליד קיר אבן עם נוף הרים"
         class="w-full h-72 object-cover object-top"
         width="900" height="450" loading="eager" />
  </div>

  <h2>למה דקלים זקוקים לגיזום קבוע</h2>
  <p>בניגוד לעצים רגילים, דקל לא "מצמיח ענפים" — הוא מצמיח כפות מרכז העץ, וכפות ישנות מתייבשות מסביב. אם לא גוזמים אותן, הן הופכות למפגע: כפות יבשות שעלולות ליפול ולפצוע, מכרסום מקננים שמושכים מזיקים, ובמקרה של דקל תמר גם פירות נופלים שמלכלכים את הסביבה.</p>
  <p>בנוסף, גיזום מקצועי משפר את המראה של הדקל ומאריך את חייו. דקל מטופל יכול לחיות 80-150 שנה בקלות.</p>

  <h2>סוגי הדקלים שאנחנו גוזמים</h2>

  <h3>וושינגטוניה (Washingtonia)</h3>
  <p>הדקל הגבוה והנפוץ ביותר ברחובות ישראל. גובה של 20-25 מטר אינו חריג. הכפות מצטברות לשרוול ארוך ויבש לאורך הגזע. גיזום נדרש פעם בשנה — הסרת כפות יבשות, ניקוי הצוואר, וניסור התפרחות לפני שהן הופכות לפירות שמלכלכים.</p>

  <h3>דקל תמר (Phoenix dactylifera)</h3>
  <p>הדקל הקלאסי המצוי בגינות פרטיות. דורש שני גיזומים בשנה: אחד באביב להסרת כפות יבשות וניקוי, ואחד אחרי הקטיף להורדת אשכולות שלא נקטפו. גיזום נכון משפר משמעותית את היבול בשנה הבאה.</p>

  <h3>דקל קנרי (Phoenix canariensis)</h3>
  <p>דקל נוי גדול ומרשים. גזם פעם בשנה-שנתיים, בעיקר אסתטי — הסרת כפות יבשות והקפדה על מראה סימטרי.</p>

  <h3>דקל מלכותי (Roystonea)</h3>
  <p>דקל גבוה ויפה במיוחד עם גזע חלק. גיזום מינימלי — בעיקר הסרת כפות שצונחות באופן טבעי וניקוי בסיס העץ.</p>

  <h3>שכן (Chamaerops) ועוד</h3>
  <p>גם דקלים נמוכים ושיחים יותר זקוקים לגיזום, בעיקר להסרת כפות יבשות והרחקת ענפים מהמדרכה.</p>

  <h2>למה לא להזניח את הדקל</h2>
  <ul>
    <li><strong>בטיחות:</strong> כפות יבשות גדולות יכולות ליפול ולגרום נזק חמור.</li>
    <li><strong>שריפות:</strong> שרוול הכפות היבשות הוא חומר דליק במיוחד, סיכון אש משמעותי בקיץ.</li>
    <li><strong>מזיקים:</strong> דקל מוזנח מושך נמלים, חרקים ומכרסמים.</li>
    <li><strong>מראה:</strong> דקל מוזנח הופך עיר עיקרית בגינה למשהו אסטטי.</li>
    <li><strong>חוק:</strong> בערים מסוימות יש חיוב חוקי לתחזק דקלים סמוכים לרחוב.</li>
  </ul>

  <h2>גיזום דקל בטיפוס לעומת מנוף</h2>
  <p>הרבה אנשים חושבים שצריך מנוף לדקל גבוה. זה לא נכון. דקל מקצועי עולה לדקל בעזרת רתמת טיפוס ומדים ייעודיים שמתאימים לגזע החלק. היתרון: עלות נמוכה משמעותית, אין צורך בכניסת רכב כבד לחצר, וגישה גם לדקלים בתוך גינה אחורית או בין מבנים.</p>
</ServiceLayout>
