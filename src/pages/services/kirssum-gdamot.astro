---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const faqs = [
  { q: 'מה ההבדל בין כריתה לכרסום?', a: 'כריתה היא חיתוך העץ עד לגובה הקרקע. לאחר הכריתה נשאר גזע (גדם) בולט מהאדמה עם שורשים עמוקים. כרסום הוא הסרת הגדם לגמרי — מכונת כרסום מחוררת ומרסקת את הגזע עד מתחת לפני הקרקע.' },
  { q: 'כמה עולה כרסום גזע?', a: 'מחיר כרסום גזע תלוי בקוטר הגזע. גזע קטן עד 20 ס"מ — 250-400 ₪. גזע בינוני 20-40 ס"מ — 400-700 ₪. גזע גדול מעל 40 ס"מ — 700-1,500 ₪. שלחו תמונה ומידות לקבלת הצעת מחיר מדויקת.' },
  { q: 'עד כמה עמוק מכרסמים?', a: 'בדרך כלל 20-40 ס"מ מתחת לפני הקרקע — מספיק לנטיעה חדשה, ריצוף או סלילה. אם נדרש עומק גדול יותר (לבנייה, למשל) אפשר להעמיק בהתאם לדרישות.' },
  { q: 'מה עושים עם שבבי הכרסום?', a: 'שבבי העץ שנוצרים בכרסום נשארים בשטח ואפשר להשתמש בהם כחיפוי אורגני בגינה, או שאנחנו מפנים אותם — לבחירתכם.' },
  { q: 'האם כרסום פוגע בצינורות תת-קרקעיים?', a: 'לפני כרסום אנחנו בודקים את מיקום תשתיות תת-קרקעיות (ביוב, חשמל, מים) ועובדים בהתאם. עומק העבודה מחושב כך שלא לפגוע בתשתיות.' }
];
---
<ServiceLayout
  title="כרסום גזעים ושורשים — בב״א גיזום | פתרון קבוע אחרי כריתת עצים"
  description="כרסום מקצועי של גדמות עצים ושורשים לאחר כריתה. מכונת כרסום מקצועית, עומק מותאם, שטח נקי לנטיעה או ריצוף. בכל הארץ, מחיר הוגן."
  h1="כרסום גזעים ושורשים — הפתרון הסופי"
  intro="אחרי כריתת עץ, נשאר גדם בקרקע שמפריע לנטיעה, לריצוף ולבנייה — ולפעמים ממשיך לצמוח. כרסום מקצועי מסלק את הגזע לחלוטין מתחת לפני הקרקע, ומשאיר שטח נקי ומוכן לכל שימוש."
  faqs={faqs}
>
  <div class="rounded-2xl overflow-hidden mb-10 shadow-soft">
    <img src="/images/gisus-gdamet.jpeg"
         alt="כרסום גדם עץ עם מכונת כרסום מקצועית ליד בית מגורים"
         class="w-full h-72 object-cover object-center"
         width="900" height="450" loading="eager" />
  </div>

  <h2>מתי צריך כרסום גזעים?</h2>
  <p>אחרי כריתת עץ, הגדם שנשאר בקרקע הוא לא רק מכשול — הוא עלול לגרום בעיות ממשיות:</p>
  <ul>
    <li><strong>הצמחה מחדש:</strong> הרבה עצים מסוגלים להנביט ירי חדשים מהגדם ומהשורשים, אפילו שנים לאחר הכריתה.</li>
    <li><strong>פטריות ומחלות:</strong> גדם מתפרק מהווה בית גידול אידיאלי לפטריות ולמחלות שיכולות להתפשט לעצים שכנים.</li>
    <li><strong>מכשול בשטח:</strong> גדם בגינה מקשה על כיסוח, הולכה ורצף חזותי.</li>
    <li><strong>שורשים שממשיכים לגדול:</strong> גם ללא עץ, שורשים פעילים יכולים להמשיך לגרום נזק לצנרת ולמדרכות.</li>
    <li><strong>תכנון גינה ובנייה:</strong> ריצוף, נטיעה חדשה או בנייה דורשים קרקע נקייה לחלוטין.</li>
  </ul>

  <h2>איך עובדת מכונת הכרסום?</h2>
  <p>מכונת כרסום (Stump Grinder) היא ציוד מיוחד עם ראש כרסום מסתובב שרוסק את הגזע לשבבים קטנים. בניגוד לחפירה ידנית שלוקחת שעות ומשאירת חור גדול — הכרסום מהיר, מדויק ומינימלי מבחינת הנזק לסביבה.</p>
  <p>אנחנו עובדים עם מכונת כרסום מקצועית שמתאימה גם לגזעים גדולים ולמקומות עם גישה מוגבלת — כולל חצרות פנימיות, גינות צרות ושטחים סמוכים לקירות.</p>

  <h2>תהליך העבודה</h2>
  <ol class="list-decimal pr-5 space-y-2">
    <li><strong>הערכה מקדמית:</strong> בודקים את גודל הגזע, עומק השורשים ואת הסביבה (תשתיות, ריצוף קיים, מרחק מגדרות וקירות).</li>
    <li><strong>הגנה על הסביבה:</strong> מניחים מגן סביב אזור הכרסום כדי שהשבבים לא יתפזרו.</li>
    <li><strong>כרסום שלבים:</strong> מרסקים את הגזע בשכבות — עד העומק הנדרש (20-40 ס"מ בדרך כלל).</li>
    <li><strong>ניקיון:</strong> אוספים את שבבי העץ לפי בחירתכם — משאירים כחיפוי או מפנים.</li>
    <li><strong>מילוי:</strong> ניתן לסיים עם מילוי החור בעפר (בתוספת מחיר) כדי שהשטח יהיה מוכן ישר לנטיעה או ריצוף.</li>
  </ol>

  <h2>כרסום לעומת חפירה ידנית — למה לבחור בכרסום?</h2>
  <p>חפירה ידנית של גדם גדול יכולה לקחת יום שלם של עבודה, לפגוע בצנרת ולהשאיר חור עמוק שקשה למלא. הכרסום המכני:</p>
  <ul>
    <li>מהיר — רוב הגזעים מכורסמים תוך שעה עד שעתיים</li>
    <li>מדויק — אפשר לשלוט בעומק ובהיקף הכרסום</li>
    <li>פחות נזק לסביבה — לא יוצר חור גדול, לא מסכן תשתיות</li>
    <li>עובד גם במקומות עם גישה מוגבלת</li>
  </ul>

  <h2>שילוב עם שירותי כריתה</h2>
  <p>ניתן לצרף כרסום גזע לכל עבודת כריתה שאנחנו מבצעים — חבילה משולבת בדרך כלל יוצאת זולה יותר מאשר שירות נפרד. אם כרתם עץ בעצמכם או עם גורם אחר, אנחנו גם מגיעים לכרסם את הגדם שנשאר.</p>
</ServiceLayout>
