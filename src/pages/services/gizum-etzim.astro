---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const faqs = [
  { q: 'מתי הזמן הכי טוב לגזום עץ?', a: 'בדרך כלל בסוף החורף ותחילת האביב (פברואר-מרץ), לפני תחילת הצמיחה. עצי פרי גוזמים אחרי הפרי. עצים נשירים גוזמים בחורף בזמן התרדמה. גיזום בטיחותי או דחוף — בכל זמן.' },
  { q: 'כמה עולה גיזום עץ?', a: 'מחיר גיזום עץ קטן עד 4 מטר נע בין 300 ל-600 ₪, עץ בינוני 4-8 מטר בין 700 ל-1,500 ₪, ועצים גבוהים מעל 8 מטר מתחילים ב-1,500 ₪. שלחו תמונה לקבלת מחיר מדויק.' },
  { q: 'גיזום בטיפוס או במנוף — מה עדיף?', a: 'בטיפוס מקצועי בדרך כלל זול יותר ב-30-50% ממנוף, ומאפשר עבודה מדויקת יותר על ענפים פנימיים. אנחנו מתמחים בטיפוס ועובדים בכל גובה. במקרים חריגים נשתמש במנוף.' },
  { q: 'האם אתם פועלים בעצי הדר וזית?', a: 'כן. אנחנו גוזמים את כל סוגי העצים — זית, הדר, דקל, פיקוס, אורן, חרוב, מנגו, אבוקדו, רימון, אגוז ועוד. לכל עץ שיטת גיזום והעיתוי המתאימים.' },
  { q: 'מה עושים עם הענפים אחרי הגיזום?', a: 'אנחנו מפנים את כל הגזם משטח העבודה. השטח נשאר נקי לחלוטין. אם הלקוח רוצה לשמור גזעים גדולים לעצי הסקה, נסדר אותם בפינה.' }
];
---
<ServiceLayout
  title="גיזום עצים מקצועי — בב״א גיזום | גוזם מוסמך משרד החקלאות"
  description="גיזום עצים מקצועי בכל גובה. גוזם מוסמך משרד החקלאות עם תעודת עבודה בגובה. מתמחים בגיזום ללא מנוף — חוסכים לכם מאות שקלים. שלחו תמונה לקבלת הצעת מחיר."
  h1="גיזום עצים מקצועי — בכל גובה"
  intro="שירות גיזום עצים מהיר, בטוח ומקצועי. גוזם מוסמך משרד החקלאות עם תעודת עבודה בגובה ושנים של ניסיון בגיזום ללא מנוף — חיסכון משמעותי לכם בעלויות, ועבודה מדויקת יותר על העץ עצמו."
  faqs={faqs}
>
  <div class="rounded-2xl overflow-hidden mb-10 shadow-soft">
    <img src="/images/gizum-etz-shemesh.jpeg"
         alt="גוזם מוסמך בטיפוס על עץ גבוה עם ציוד בטיחות מקצועי"
         class="w-full h-72 object-cover object-center"
         width="900" height="450" loading="eager" />
  </div>

  <h2>למה לבחור בנו לגיזום העצים שלכם</h2>
  <p>גיזום הוא אחד הכלים החשובים ביותר לשמירה על בריאות העץ ולמניעת סכנות. עץ שלא נגזם לאורך שנים יוצר בעיות: ענפים שבריריים שעלולים ליפול, שורשים שמרימים מדרכות וצנרת, צל מוגזם, ופגיעה בקווי חשמל ובמבנים. מצד שני, גיזום שגוי עלול להזיק לעץ לטווח ארוך — לקצץ ענפים מרכזיים, לחשוף את העץ למזיקים, או לפגוע בצורה הטבעית שלו.</p>
  <p>אנחנו עובדים לפי הסטנדרטים של משרד החקלאות, עם הבנה אמיתית של ביולוגיית העץ, ולא רק "חיתוך מהיר". כל גיזום מתחיל בהערכה: מה מטרת הגיזום (בטיחות, אסתטיקה, בריאות העץ או רגולציה), אילו ענפים להוריד ואילו לשמר, ומה השיטה המתאימה ביותר.</p>

  <h2>סוגי גיזום שאנחנו מבצעים</h2>
  <h3>גיזום בטיחותי</h3>
  <p>הסרת ענפים יבשים, שבורים או נטויים שעלולים ליפול. עדיפות עליונה למניעת נזק לרכוש, לרכבים ולאנשים. זה גם הגיזום שחברות הביטוח בדרך כלל דורשות.</p>

  <h3>גיזום עיצוב</h3>
  <p>עיצוב צורת העץ — הקטנת נפח, איזון בין הצדדים, פתיחת מבט, מניעת התחככות בקירות וגגות. נעשה במחשבה לטווח ארוך, לא רק להופעה הנוכחית.</p>

  <h3>גיזום בריאותי</h3>
  <p>הסרת ענפים חולים, נגועים במזיקים, יבשים או מתחככים זה בזה. מאפשר לעץ להפנות אנרגיה לחלקים בריאים, מצמצם הפצת מחלות, ומאריך את חיי העץ.</p>

  <h3>גיזום עצי פרי</h3>
  <p>גיזום מותאם לכל סוג עץ פרי (זית, הדר, אבוקדו, מנגו, רימון, אגוז) — בעיתוי הנכון ועם השיטה הנכונה כדי להגביר את היבול ולשמור על נגישות לקטיף.</p>

  <h3>גיזום קווי חשמל</h3>
  <p>גיזום בטיחותי של ענפים שקרובים לקווי חשמל. עבודה רגישה שמחייבת תיאום מראש ומומחיות גבוהה.</p>

  <h2>היתרון של גיזום בטיפוס לעומת מנוף</h2>
  <p>הרבה חברות עובדות רק עם מנוף, ומוסיפות 500-1,200 ₪ לעלות העבודה. אנחנו מתמחים בגיזום בטיפוס מקצועי — קושרים עצמנו עם רתמות ייעודיות לעבודה בגובה ומגיעים לכל ענף, גם בתוך נוף העץ. היתרונות:</p>
  <ul>
    <li>חיסכון משמעותי בעלות (אין הוצאת מנוף)</li>
    <li>גישה לענפים פנימיים שמנוף לא יכול להגיע אליהם</li>
    <li>אין צורך בנגישות לכלי רכב כבד (רחובות צרים, חצרות סגורות)</li>
    <li>פחות הרס סביבתי ופחות לכלוך</li>
    <li>עבודה מהירה יותר כשהשטח אינו ידידותי למנוף</li>
  </ul>

  <h2>תהליך העבודה אצלנו</h2>
  <p>אתם שולחים לנו תמונה של העץ בוואטסאפ — ובדרך כלל אנחנו מספיקים לתת הצעת מחיר תוך דקות ספורות. אם נדרש ביקור הערכה לעבודה מורכבת, נגיע ללא עלות ובלי התחייבות.</p>
  <p>במועד שתיאמנו, מגיעים בזמן עם כל הציוד — מסור מקצועי, רתמת טיפוס, חבלים מתאימים, מסור גזם, חוטים. עובדים בבטיחות מלאה (תעודת עבודה בגובה הכרחית), עם דגש על שמירה על הסביבה ועל הרכוש שלכם. לסיום, מפנים את כל הגזם לאתר פסולת מורשה.</p>

  <h2>אזורי שירות</h2>
  <p>אנחנו פועלים ברוב אזורי הארץ. בערים הגדולות במרכז (תל אביב, רמת גן, גבעתיים, הרצליה, רעננה, פ"ת, חולון) הזמינות גבוהה במיוחד ולעיתים אפשר להגיע באותו יום. צרו קשר לבדוק זמינות באזורכם.</p>
</ServiceLayout>
