---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQSchema from '../components/FAQSchema.astro';
import { SITE, SERVICES, TRUST_SIGNALS, PROCESS_STEPS, FAQS, TESTIMONIALS, CITIES } from '../data/site';

const title = 'בב"א גיזום — גיזום וכריתת עצים בכל הארץ | גוזם מוסמך משרד החקלאות';
const description = 'בב"א גיזום — שירות מקצועי של גיזום עצים, כריתת עצים וגיזום דקלים בכל חלקי הארץ. גוזם וכורת מוסמך משרד החקלאות, תעודה לעבודה בגובה, התמחות בגיזום ללא מנוף. שלחו תמונה בוואטסאפ לקבלת הצעת מחיר.';
---
<BaseLayout title={title} description={description}>
  <FAQSchema slot="head-extra" faqs={FAQS} />

  {/* HERO */}
  <section class="relative overflow-hidden bg-gradient-to-bl from-forest-900 via-forest-800 to-forest-700 text-white">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 24px 24px;"></div>
    <div class="container-x section relative">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="eyebrow !text-accent-500">שירות ארצי • החל מ-250 ₪</span>
          <h1 class="h1 text-white mb-5">
            גיזום וכריתת עצים מקצועי<br />
            <span class="text-accent-500">בכל חלקי הארץ</span>
          </h1>
          <p class="lead !text-sand-100 mb-8 max-w-xl">
            גוזם וכורת מוסמך באישור משרד החקלאות, עם תעודה לעבודה בגובה ושנים של ניסיון בגיזום ללא מנוף — חיסכון משמעותי בעלויות לכם.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('שלום, אשמח לקבל הצעת מחיר. מצורפת תמונה.')}`} target="_blank" rel="noopener" class="btn-whatsapp text-base">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.6 6.32A8.78 8.78 0 0012 4 8.84 8.84 0 003.16 12.84 8.7 8.7 0 004.4 17.5L4 20l2.6-.36A8.83 8.83 0 0012 21.68 8.84 8.84 0 0020.84 12.84 8.78 8.78 0 0017.6 6.32z"/></svg>
              שלחו תמונה בוואטסאפ
            </a>
            <a href={`tel:${SITE.phoneRaw}`} class="btn-accent text-base">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.793a2 2 0 01-.45 1.847L8.09 10.91a16 16 0 005 5l1.755-1.38a2 2 0 011.847-.45l2.793.7A2 2 0 0121 16.72V19a2 2 0 01-2 2A16 16 0 013 5z"/></svg>
              {SITE.phone}
            </a>
          </div>

          <ul class="mt-8 grid grid-cols-2 gap-3 text-sm">
            <li class="flex items-center gap-2 text-sand-100"><svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> רישיון משרד החקלאות</li>
            <li class="flex items-center gap-2 text-sand-100"><svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> תעודת עבודה בגובה</li>
            <li class="flex items-center gap-2 text-sand-100"><svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> מומחיות ללא מנוף</li>
            <li class="flex items-center gap-2 text-sand-100"><svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> פינוי גזם מלא</li>
          </ul>
        </div>

        <div class="lg:pr-6">
          <div class="bg-white/95 backdrop-blur rounded-2xl p-1.5 shadow-strong">
            <div class="bg-forest-900 rounded-xl px-5 py-3 flex items-center justify-between">
              <span class="text-white font-semibold">קבלו הצעת מחיר עכשיו</span>
              <span class="text-accent-500 text-sm font-bold">תוך דקות</span>
            </div>
            <div class="p-5">
              <ContactForm />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* WHY US */}
  <section class="section bg-sand-50">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">למה לבחור בנו</span>
        <h2 class="h2 mb-4">גוזם מוסמך, מקצועי ועם יחס אישי</h2>
        <p class="lead">היתרון של בב"א הוא שילוב נדיר של אישורים רשמיים, ניסיון אמיתי בעבודה בגובה, ומחיר הוגן ללא הפתעות.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {TRUST_SIGNALS.map(item => (
          <div class="card">
            <div class="w-12 h-12 rounded-xl bg-forest-700 text-white flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.07 3.07 0 001.745-.723 3.07 3.07 0 013.976 0 3.07 3.07 0 001.745.723 3.07 3.07 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.07 3.07 0 010 3.976 3.07 3.07 0 00-.723 1.745 3.07 3.07 0 01-2.812 2.812 3.07 3.07 0 00-1.745.723 3.07 3.07 0 01-3.976 0 3.07 3.07 0 00-1.745-.723 3.07 3.07 0 01-2.812-2.812 3.07 3.07 0 00-.723-1.745 3.07 3.07 0 010-3.976 3.07 3.07 0 00.723-1.745 3.07 3.07 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            </div>
            <h3 class="h3 mb-2">{item.title}</h3>
            <p class="text-forest-700/80 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* SERVICES */}
  <section class="section bg-white">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">השירותים שלנו</span>
        <h2 class="h2 mb-4">פתרון מקצה לקצה לכל עץ</h2>
        <p class="lead">מגיזום קל ועד כריתה מורכבת, אנחנו מבצעים את הכל במו ידינו — בלי קבלני משנה ובלי הפתעות.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {SERVICES.map(s => (
          <a href={`/services/${s.slug}`} class="card group block hover:bg-forest-50">
            <div class="w-12 h-12 rounded-xl bg-forest-100 text-forest-700 flex items-center justify-center mb-4 group-hover:bg-forest-700 group-hover:text-white transition">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10 1.5c-1 3-4 4-4 7 0 2 1.5 3.5 4 3.5s4-1.5 4-3.5c0-3-3-4-4-7zM9 13h2v6H9z"/></svg>
            </div>
            <h3 class="h3 mb-2 group-hover:text-forest-900">{s.title}</h3>
            <p class="text-forest-700/80 leading-relaxed">{s.short}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-forest-700 font-semibold group-hover:gap-2 transition-all">
              קראו עוד
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* PROCESS */}
  <section class="section bg-forest-50">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">איך זה עובד</span>
        <h2 class="h2 mb-4">תהליך פשוט, שקוף ומהיר</h2>
        <p class="lead">מהפנייה הראשונה ועד פינוי הגזם — אתם יודעים בדיוק מה לצפות.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 relative">
        {PROCESS_STEPS.map(step => (
          <div class="bg-white rounded-2xl p-6 shadow-soft relative">
            <span class="absolute -top-4 right-6 inline-flex items-center justify-center w-12 h-12 rounded-full bg-accent-500 text-forest-900 font-bold text-lg shadow-soft">{step.num}</span>
            <h3 class="h3 mt-4 mb-2">{step.title}</h3>
            <p class="text-forest-700/80 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* GALLERY */}
  <section class="section bg-white">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">מהשטח</span>
        <h2 class="h2 mb-4">תיק עבודות</h2>
        <p class="lead">מבחר עבודות אמיתיות מהשטח. לפרטים — שלחו תמונה בוואטסאפ.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/gizum-etz-oren.jpeg"
               alt="גוזם מוסמך עולה על עץ אורן גבוה עם ציוד גיזום מקצועי"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/hero-gozem-etz.jpeg"
               alt="גוזם מקצועי על ראש עץ מחייך עם מסור שרשרת"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/kritat-etz-manof.jpeg"
               alt="כריתת עץ בסיוע מנוף ועגורן בסביבה עירונית"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/gizum-dekel-even.jpeg"
               alt="גיזום דקל תמר ליד קיר אבן עם נוף הרים ברקע"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/kritat-oren.jpeg"
               alt="כריתת עץ אורן גבוה על רקע שמיים כחולים"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
        <div class="aspect-square overflow-hidden rounded-xl shadow-soft">
          <img src="/images/pinui-gezem-traktor.jpeg"
               alt="פינוי גזם עצים עם טרקטור קדמי בשטח פתוח"
               class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
               loading="lazy" width="600" height="600" />
        </div>
      </div>
    </div>
  </section>

  {/* TESTIMONIALS */}
  <section class="section bg-forest-50">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">מה אומרים עלינו</span>
        <h2 class="h2 mb-4">לקוחות מספרים</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {TESTIMONIALS.map(t => (
          <div class="card">
            <div class="flex gap-1 text-accent-500 mb-3">
              {Array(t.rating).fill(0).map(() => (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-forest-800 leading-relaxed mb-4">"{t.text}"</p>
            <div class="font-semibold text-forest-900">{t.name}</div>
            <div class="text-sm text-forest-600">{t.location}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* AREAS */}
  <section class="section bg-white">
    <div class="container-x">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">אזורי שירות</span>
        <h2 class="h2 mb-4">עובדים בכל הארץ</h2>
        <p class="lead">אנחנו מגיעים לכל יישוב בישראל. הנה כמה מהיישובים שאנחנו פעילים בהם:</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {CITIES.map(c => (
          <a href={`/areas/${c.slug}`} class="bg-forest-50 hover:bg-forest-100 px-4 py-3 rounded-lg text-forest-800 font-medium text-center transition">
            גיזום ב{c.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="section bg-sand-50">
    <div class="container-x max-w-4xl">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="eyebrow">שאלות נפוצות</span>
        <h2 class="h2 mb-4">כל מה שרציתם לדעת</h2>
      </div>

      <div class="space-y-3">
        {FAQS.map(faq => (
          <details class="group bg-white rounded-xl shadow-soft overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 font-semibold text-forest-900 hover:bg-forest-50">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-forest-600 group-open:rotate-180 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </summary>
            <div class="px-6 pb-5 text-forest-700/90 leading-relaxed">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* FINAL CTA */}
  <section class="section bg-gradient-to-bl from-forest-700 to-forest-900 text-white">
    <div class="container-x text-center max-w-3xl">
      <h2 class="h2 text-white mb-4">מוכנים להתחיל?</h2>
      <p class="lead !text-sand-100 mb-8">שלחו תמונה של העץ בוואטסאפ או התקשרו — אנחנו עונים מהר ונותנים הצעת מחיר הוגנת ושקופה.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener" class="btn-whatsapp text-base">וואטסאפ — תמונה והצעת מחיר</a>
        <a href={`tel:${SITE.phoneRaw}`} class="btn-accent text-base">{SITE.phone}</a>
      </div>
    </div>
  </section>
</BaseLayout>
