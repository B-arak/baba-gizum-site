---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (d: Date) => new Intl.DateTimeFormat('he-IL', { dateStyle: 'long' }).format(d);

const heroImage = post.data.heroImage ?? SITE.socialImage;
const heroAlt  = post.data.heroAlt  ?? post.data.title;
const canonicalUrl = `${SITE.url}/blog/${post.slug}`;

// HowTo schema for step-by-step posts
const howToSchemas: Record<string, object> = {
  'ishur-kritat-etz': {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך מקבלים אישור כריתת עץ בישראל',
    description: 'תהליך שלב-אחר-שלב לקבלת אישור כריתת עץ מפקיד יערות',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'הגשת בקשה', text: 'מגישים טופס בקשה לפקיד היערות ברשות המקומית עם תמונות ומידות העץ' },
      { '@type': 'HowToStep', position: 2, name: 'ביקור פקיד', text: 'פקיד היערות מבצע ביקור בשטח ובודק את הצורך בכריתה' },
      { '@type': 'HowToStep', position: 3, name: 'קבלת האישור', text: 'מקבלים אישור בכתב — רק אז מותר לכרות' },
      { '@type': 'HowToStep', position: 4, name: 'ביצוע הכריתה', text: 'כורתים את העץ עם גוזם מוסמך מטעם משרד החקלאות' }
    ],
    estimatedCost: { '@type': 'MonetaryAmount', currency: 'ILS', value: '0', description: 'הגשת הבקשה חינם; עץ חלופי עשוי לעלות 500–5,000 ₪' },
    totalTime: 'P4W'
  },
  'matai-lagzom-etz': {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'איך לבחור את עונת הגיזום הנכונה',
    description: 'מדריך שלבים לבחירת העיתוי הנכון לגיזום עץ',
    step: [
      { '@type': 'HowToStep', position: 1, name: 'זהה את סוג העץ', text: 'עץ נשיר, עץ פרי, דקל — לכל סוג עיתוי שונה' },
      { '@type': 'HowToStep', position: 2, name: 'בדוק בטיחות', text: 'אם יש ענף שבור או מסוכן — גוזמים מיד ללא קשר לעונה' },
      { '@type': 'HowToStep', position: 3, name: 'עצים רגילים', text: 'סוף חורף–תחילת אביב (ינואר–מרץ) היא העונה האידיאלית לרוב העצים' },
      { '@type': 'HowToStep', position: 4, name: 'עצי פרי', text: 'גזום לפי הסוג: זית בפברואר–מרץ, הדרים במרץ–אפריל, מנגו ואבוקדו אחרי הקטיף' }
    ]
  }
};

const howToSchema = howToSchemas[post.slug];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: post.data.author },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  image: heroImage ? `${SITE.url}${heroImage}` : undefined
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'בית', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'בלוג', item: `${SITE.url}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalUrl }
  ]
};
---
<BaseLayout title={post.data.title} description={post.data.description} ogImage={heroImage}>
  <script slot="head-extra" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="head-extra" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {howToSchema && <script slot="head-extra" type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}

  <article class="bg-white">
    <header class="bg-gradient-to-bl from-forest-900 via-forest-800 to-forest-700 text-white">
      <div class="container-x section">
        <nav class="text-sm text-sand-200 mb-4" aria-label="פירורי לחם">
          <a href="/" class="hover:text-white">בית</a>
          <span class="mx-2">›</span>
          <a href="/blog" class="hover:text-white">בלוג</a>
        </nav>
        <h1 class="h1 text-white mb-4 max-w-4xl">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sand-200">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>•</span>
          <span>מאת {post.data.author}</span>
        </div>
      </div>
    </header>

    {heroImage && (
      <div class="w-full max-h-[460px] overflow-hidden bg-forest-900">
        <img
          src={heroImage}
          alt={heroAlt}
          class="w-full max-h-[460px] object-cover object-center"
          width="1200" height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )}

    <section class="section">
      <div class="container-x grid lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 prose prose-lg max-w-none [&_h2]:text-forest-900 [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-3xl [&_h2]:font-bold [&_h3]:text-forest-900 [&_h3]:mt-6 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-bold [&_p]:leading-relaxed [&_p]:text-forest-800 [&_p]:mb-4 [&_ul]:list-disc [&_ul]:pr-5 [&_ul]:space-y-2 [&_ul]:mb-4 [&_ol]:list-decimal [&_ol]:pr-5 [&_ol]:space-y-2 [&_ol]:mb-4 [&_li]:text-forest-800 [&_strong]:text-forest-900 [&_a]:text-forest-700 [&_a]:underline">
          <Content />
        </div>
        <aside class="space-y-6">
          <div class="bg-forest-700 text-white rounded-2xl p-6 sticky top-24">
            <h3 class="font-bold mb-3">צריכים גוזם?</h3>
            <p class="mb-5 text-sand-100 text-sm">שלחו תמונה — נחזיר הצעת מחיר תוך דקות.</p>
            <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener" class="btn-accent w-full mb-2">וואטסאפ</a>
            <a href={`tel:${SITE.phoneRaw}`} class="btn-whatsapp w-full">{SITE.phone}</a>
          </div>
        </aside>
      </div>
    </section>
  </article>
</BaseLayout>
