---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (d: Date) => new Intl.DateTimeFormat('he-IL', { dateStyle: 'long' }).format(d);
---
<BaseLayout
  title="הבלוג של בב״א גיזום | מדריכים מקצועיים על גיזום וכריתת עצים"
  description="מדריכים מקצועיים, טיפים ומאמרים על גיזום עצים, כריתת עצים, קבלת אישורים והכל מה שצריך לדעת על תחזוקת עצים בישראל."
>
  <section class="bg-gradient-to-bl from-forest-900 via-forest-800 to-forest-700 text-white">
    <div class="container-x section">
      <h1 class="h1 text-white mb-5">הבלוג של בב״א</h1>
      <p class="lead !text-sand-100 max-w-2xl">מדריכים מקצועיים, טיפים ושאלות נפוצות בנושא גיזום עצים, כריתה וטיפול בגינה — מהאנשים שעושים את זה בפועל.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-x">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="card block hover:bg-forest-50 group !p-0 overflow-hidden">
            <div class="aspect-video overflow-hidden rounded-t-2xl bg-forest-800">
              {post.data.heroImage
                ? <img
                    src={post.data.heroImage}
                    alt={post.data.heroAlt ?? post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    width="600" height="338"
                    loading="lazy"
                  />
                : <div class="w-full h-full bg-gradient-to-br from-forest-200 to-forest-500 flex items-center justify-center text-white">
                    <svg class="w-16 h-16 opacity-70" fill="currentColor" viewBox="0 0 20 20"><path d="M10 1.5c-1 3-4 4-4 7 0 2 1.5 3.5 4 3.5s4-1.5 4-3.5c0-3-3-4-4-7z"/></svg>
                  </div>
              }
            </div>
            <div class="p-6">
            <div class="flex items-center gap-2 text-xs text-forest-600 mb-2">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              {post.data.tags.length > 0 && <span>•</span>}
              {post.data.tags.slice(0, 2).map(t => <span class="bg-forest-100 px-2 py-0.5 rounded">{t}</span>)}
            </div>
            <h2 class="h3 mb-2 group-hover:text-forest-900">{post.data.title}</h2>
            <p class="text-forest-700/80 leading-relaxed line-clamp-3">{post.data.description}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-forest-700 font-semibold group-hover:gap-2 transition-all">
              קראו את הפוסט
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
            </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
